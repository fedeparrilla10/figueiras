---
import { houseReviews } from '../data/reviews';
---

<div class="flex flex-col items-center justify-center gap-14">
  <h3 class="uppercase text-2xl md:text-4xl text-center text-sky-700">
    Qué dicen de nuestras <br />casas rurales en <span class="font-bold"
      >Asturias</span
    >
  </h3>

  <div
    class="flex flex-row gap-7 bg-gray-100 w-screen items-center justify-center px-12 py-16"
  >
    {
      houseReviews.map((reviews) => {
        const { review, title, description, name, house, date } = reviews;

        return (
          <div class="grid grid-cols-1 grid-rows-1 h-[500px] w-[360px] shadow-xl bg-gray-50">
            <div class="grid grid-cols-1 grid-rows-3 p-4">
              <div class="flex flex-col gap-2">
                <h4 class="text-2xl font-bold text-sky-600">{review}</h4>
                <p class="font-bold">{title}</p>
              </div>

              <p class="text-gray-600 text-[0.95rem]">{description}</p>

              <a href="#" class="text-sky-600 font-bold pt-20">
                Ver más
              </a>
            </div>
            <div class="bg-sky-500 flex flex-col gap-3 p-4">
              <h3 class="text-sky-700 font-bold uppercase">{name}</h3>
              <p class="text-gray-50">
                {house} | {date}
              </p>
            </div>
          </div>
        );
      })
    }
  </div>
</div>
