---

---

<div class="flex flex-col gap-5">
  <h2 class="uppercase text-xl lg:text-5xl text-sky-700 font-bold text-center">
    Reservar <span class="font-normal">Casa das Figueiras</span>
  </h2>

  <div
    class="flex items-center gap-5 lg:gap-32 border rounded-xl p-4 m-4 flex-wrap md:flex-nowrap"
  >
    <div class="flex flex-col">
      <label for="inDate" class="text-gray-400">Llegada</label>
      <input type="date" name="inDate" id="inDate" />
    </div>

    <div class="flex flex-col">
      <label for="outDate" class="text-gray-400">Salida</label>
      <input type="date" name="outDate" id="outDate" />
    </div>

    <div class="flex flex-col w-full lg:w-auto">
      <label for="guests" class="text-gray-400">Personas</label>
      <select name="guests" id="guests" class="w-48">
        <option value="1">1</option>
        <option value="2">2</option>
        <option value="3">3</option>
        <option value="4">4</option>
      </select>
    </div>

    <div class="w-full">
      <button
        class="bg-blue-600 text-white px-20 py-2 rounded-md w-full lg:w-auto"
        >Buscar</button
      >
    </div>
  </div>
</div>
